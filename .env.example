# Azure Cosmos DB Configuration
AZURE_COSMOSDB_ENDPOINT_DEV=https://your-cosmos-dev.documents.azure.com:443/
AZURE_COSMOSDB_KEY_DEV=your-cosmos-key-dev
AZURE_COSMOSDB_ENDPOINT_PROD=https://your-cosmos-prod.documents.azure.com:443/
AZURE_COSMOSDB_KEY_PROD=your-cosmos-key-prod

# Azure Functions Configuration
AZURE_FUNCTIONS_URL_DEV=http://localhost:7071
AZURE_FUNCTIONS_URL_PROD=https://your-functions-app.azurewebsites.net
AZURE_FUNCTIONS_KEY=your-functions-key

# Azure OpenAI Configuration
AZURE_OPENAI_ENDPOINT=https://your-openai.openai.azure.com/
AZURE_OPENAI_KEY=your-openai-key
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4

# Azure Blob Storage Configuration
AZURE_STORAGE_ACCOUNT_NAME=your-storage-account
AZURE_STORAGE_ACCOUNT_KEY=your-storage-key

# Azure Application Insights
AZURE_APPLICATION_INSIGHTS_CONNECTION_STRING=InstrumentationKey=your-key;IngestionEndpoint=https://your-region.in.applicationinsights.azure.com/