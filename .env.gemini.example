# Google Gemini API Configuration
# Copy this file to .env.gemini and fill in your values

# Google API Key (Required)
GOOGLE_API_KEY=your-gemini-api-key

# Model Configuration
GEMINI_MODEL=gemini-2.5-pro

# File Search Store (will be set after setup_file_store.py runs)
FILE_SEARCH_STORE_NAME=

# Generation Settings
QUESTIONS_PER_CATEGORY=15
TEMPERATURE=0.7
