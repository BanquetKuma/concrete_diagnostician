    "dotenv": "^16.4.5",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "marked": "^17.0.1",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "~5.9.2"
