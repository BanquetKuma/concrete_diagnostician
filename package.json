{
  "name": "concrete_diagnostician",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "start:tunnel": "expo start --tunnel --clear",
    "start:codespaces": "expo start --tunnel --clear",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "lint:fix": "expo lint --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "typecheck": "npx tsc --noEmit",
    "rag:upload": "tsx scripts/rag/uploadPDF.ts",
    "rag:create-index": "tsx scripts/rag/createIndex.ts",
    "rag:create-datasource": "tsx scripts/rag/createDataSource.ts",
    "rag:test-search": "tsx scripts/rag/testSearch.ts",
    "rag:python:setup-venv": "bash scripts/rag/setup_venv.sh",
    "rag:python:datasource": "python scripts/rag/create_datasource.py",
    "rag:python:skillset": "python scripts/rag/create_skillset.py",
    "rag:python:indexer": "python scripts/rag/create_indexer.py",
    "rag:python:setup": "python scripts/rag/setup_rag_pipeline.py"
